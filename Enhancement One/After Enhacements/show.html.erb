<div class="container py-4">
  <div class="row">
    <div class="col-lg-8 offset-lg-2">
      <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white">
          <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
            <h1 class="h3 mb-0">
              Category Details
            </h1>

            <div class="d-flex gap-2">
              <%= link_to "Go Back", "/categories", class: "btn btn-light btn-sm" %>

              <%= link_to(
                    "Delete",
                    "/delete_category/#{@the_category.id}",
                    class: "btn btn-danger btn-sm",
                    data: { confirm: "Are you sure you want to delete this category?" }
                  ) %>
            </div>
          </div>
        </div>

        <div class="card-body">
          <dl class="row mb-0">
            <dt class="col-sm-4">Landlord</dt>
            <dd class="col-sm-8"><%= @the_category.landlord_id %></dd>

            <dt class="col-sm-4">Category</dt>
            <dd class="col-sm-8"><%= @the_category.category %></dd>

            <dt class="col-sm-4">Created</dt>
            <dd class="col-sm-8"><%= time_ago_in_words(@the_category.created_at) %> ago</dd>

            <dt class="col-sm-4">Updated</dt>
            <dd class="col-sm-8"><%= time_ago_in_words(@the_category.updated_at) %> ago</dd>
          </dl>
        </div>
      </div>

      <div class="card shadow-sm">
        <div class="card-header">
          <h2 class="h5 mb-0">Edit Category</h2>
        </div>

        <div class="card-body">
          <%= form_with(url: "/modify_category/#{@the_category.id}", method: "post", local: true) do %>
            <div class="mb-3">
              <%= label_tag(:query_landlord_id, "Landlord ID", class: "form-label") %>
              <%= number_field_tag(
                    :query_landlord_id,
                    @the_category.landlord_id,
                    class: "form-control"
                  ) %>
            </div>

            <div class="mb-4">
              <%= label_tag(:query_category, "Category", class: "form-label") %>
              <%= text_field_tag(
                    :query_category,
                    @the_category.category,
                    class: "form-control"
                  ) %>
            </div>

            <div class="d-grid">
              <%= submit_tag("Update Category", class: "btn btn-primary") %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
