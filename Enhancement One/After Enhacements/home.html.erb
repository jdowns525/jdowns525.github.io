<div class="container py-4">
  <div class="row mb-4">
    <div class="col-lg-12">
      <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
          <h1 class="h3 mb-0">My Landlord Ratings</h1>
        </div>

        <div class="card-body">
          <p class="lead mb-0">
            Search landlords, read tenant reviews, and share rental experiences with other users.
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="row mb-4">
    <div class="col-lg-12">
      <div class="card shadow-sm">
        <div class="card-body">
          <%= form_with(url: "/landlords", method: "get", local: true, html: { class: "row g-3 align-items-end" }) do %>
            <div class="col-md-10">
              <%= label_tag(:search, "Search Landlords", class: "form-label") %>
              <%= text_field_tag(
                    :search,
                    params[:search],
                    placeholder: "Search by landlord, address, or neighborhood...",
                    class: "form-control"
                  ) %>
              <div class="form-text">
                Enter a landlord name, address, or neighborhood to search.
              </div>
            </div>

            <div class="col-md-2 d-grid">
              <%= submit_tag("Search", class: "btn btn-primary") %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-12">
      <div class="card shadow-sm">
        <div class="card-header">
          <h2 class="h5 mb-0">Recent Reviews</h2>
        </div>

        <div class="card-body">
          <% if @reviews.present? %>
            <div class="table-responsive">
              <table class="table table-striped table-hover align-middle">
                <thead class="table-light">
                  <tr>
                    <th scope="col">Stars</th>
                    <th scope="col">Move In</th>
                    <th scope="col">Move Out</th>
                    <th scope="col">Review</th>
                    <th scope="col">Useful</th>
                    <th scope="col">City</th>
                    <th scope="col">Maintenance</th>
                    <th scope="col">Respectful</th>
                    <th scope="col">Responsive</th>
                  </tr>
                </thead>

                <tbody>
                  <% @reviews.each do |review| %>
                    <tr>
                      <td><%= review.stars %></td>
                      <td><%= review.date_occupancy %></td>
                      <td><%= review.date_vacancy %></td>
                      <td><%= truncate(review.text, length: 80) %></td>
                      <td><%= review.useful %></td>
                      <td><%= review.city %></td>
                      <td><%= review.maintenance_and_repairs %></td>
                      <td><%= review.respectfulness %></td>
                      <td><%= review.responsiveness %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>

            <div class="d-flex justify-content-center mt-3">
              <%= will_paginate @reviews %>
            </div>
          <% else %>
            <div class="alert alert-info mb-0">
              No reviews are available yet.
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
