<div class="container py-4">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
      <h1 class="h3 mb-1">Categories</h1>
      <p class="text-muted mb-0">
        Manage landlord categories and organize landlord records.
      </p>
    </div>
  </div>

  <div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white">
      <h2 class="h5 mb-0">Add a New Category</h2>
    </div>

    <div class="card-body">
      <%= form_with(url: "/insert_category", method: "post", local: true) do %>
        <div class="row g-3 align-items-end">
          <div class="col-md-5">
            <%= label_tag(:query_landlord_id, "Landlord ID", class: "form-label") %>
            <%= number_field_tag(
                  :query_landlord_id,
                  nil,
                  class: "form-control",
                  placeholder: "Enter landlord ID"
                ) %>
          </div>

          <div class="col-md-5">
            <%= label_tag(:query_category, "Category", class: "form-label") %>
            <%= text_field_tag(
                  :query_category,
                  nil,
                  class: "form-control",
                  placeholder: "Enter category"
                ) %>
          </div>

          <div class="col-md-2 d-grid">
            <%= submit_tag("Create", class: "btn btn-primary") %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="card-header">
      <h2 class="h5 mb-0">All Categories</h2>
    </div>

    <div class="card-body">
      <% if @list_of_categories.present? %>
        <div class="table-responsive">
          <table class="table table-striped table-hover align-middle">
            <thead class="table-light">
              <tr>
                <th scope="col">ID</th>
                <th scope="col">Landlord</th>
                <th scope="col">Category</th>
                <th scope="col">Created</th>
                <th scope="col">Updated</th>
                <th scope="col" class="text-end">Actions</th>
              </tr>
            </thead>

            <tbody>
              <% @list_of_categories.each do |a_category| %>
                <tr>
                  <td><%= a_category.id %></td>
                  <td><%= a_category.landlord_id %></td>
                  <td><%= a_category.category %></td>
                  <td><%= time_ago_in_words(a_category.created_at) %> ago</td>
                  <td><%= time_ago_in_words(a_category.updated_at) %> ago</td>
                  <td class="text-end">
                    <%= link_to "Details", "/categories/#{a_category.id}", class: "btn btn-sm btn-primary" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="alert alert-info mb-0">
          No categories have been added yet.
        </div>
      <% end %>
    </div>
  </div>
</div>
